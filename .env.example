# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# NextAuth
NEXTAUTH_URL=http://localhost:3000          # Change to your Vercel URL in production
NEXTAUTH_SECRET=                           # Generate: openssl rand -base64 32

# Access control (optional — leave blank to allow any Google account)
ALLOWED_EMAIL_DOMAIN=eunomiapharma.com     # Restrict to this domain, OR:
ALLOWED_EMAILS=                            # Comma-separated list of specific emails

# Vercel KV — these are added automatically when you connect a KV store in Vercel dashboard.
# For local dev, copy them from: Vercel dashboard > Storage > your KV store > .env.local
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
